{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@maps-viewer/shared": ["packages/shared/src/index.ts"],
      "@maps-viewer/shared/*": ["packages/shared/src/*"],
      "@maps-viewer/core": ["packages/core/src/index.ts"],
      "@maps-viewer/core/*": ["packages/core/src/*"]
    }
  },
  "exclude": ["**/dist", "**/node_modules"]
}
